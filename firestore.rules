rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data.
    // Any authenticated user can read user data — UIDs are never publicly discoverable,
    // so only users connected through a community will ever attempt a read.
    // Writes remain restricted to the owning user only.
    match /users/{uid}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Community documents
    match /communities/{communityId} {
      // Any authenticated user can read (needed for invite code lookup)
      allow read: if request.auth != null;
      // Any authenticated user can create a community
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      // Members and owners can update (add messages, accept workouts, etc.)
      // Also allow if the user is adding themselves as a new member (join via invite code)
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.get('memberIds', [])
            || request.auth.uid in request.resource.data.get('memberIds', []));
      // Only the owner can delete
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
